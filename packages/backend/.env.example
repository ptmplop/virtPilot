PORT=3001
NODE_ENV=development

# Storage paths (absolute)
STORAGE_ROOT=/var/lib/virtpilot
TEMPLATES_DIR=/var/lib/virtpilot/templates
ISOS_DIR=/var/lib/virtpilot/isos
VMS_DIR=/var/lib/virtpilot/vms
CLOUD_INIT_DIR=/var/lib/virtpilot/cloud-init

# Network bridge (must exist on host)
DEFAULT_BRIDGE=br0

# Virsh connection URI (default: local system)
LIBVIRT_URI=qemu:///system

# Authentication — set a strong password and a random JWT secret
AUTH_PASSWORD=changeme
JWT_SECRET=replace-with-a-long-random-secret
